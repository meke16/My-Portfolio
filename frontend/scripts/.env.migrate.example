# Copy to scripts/.env.migrate and fill in (file is gitignored via .env.migrate pattern)

# Neon: Dashboard → your project → Connection string → URI (include ?sslmode=require if needed)
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require

# Path to Firebase service account JSON (Project settings → Service accounts → Generate key)
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/serviceAccountKey.json
