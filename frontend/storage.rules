rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /profile/{file=**} {
      allow read: if true;
      allow write: if request.auth != null
        && request.resource.size < 10 * 1024 * 1024;
    }

    match /projects/{file=**} {
      allow read: if true;
      allow write: if request.auth != null
        && request.resource.size < 10 * 1024 * 1024;
    }
  }
}
